# Backend
DATABASE_URL=postgresql://user:pass@localhost:5432/itsm
SECRET_KEY=generar_una_clave_larga_y_segura_aqui

# CORS: dominio(s) del frontend (Vercel producción + local). Separados por coma, sin espacios extra.
ALLOWED_ORIGINS=http://localhost:5173,https://tu-app.vercel.app

# Opcional (Railway + previews Vercel): regex para orígenes; no sustituye ALLOWED_ORIGINS para el dominio principal.
# Ejemplo: https://.*\.vercel\.app
# ALLOWED_ORIGIN_REGEX=

# Railway inyecta PORT; start.sh lo usa. Localmente suele ser 8000.

# Graph API (Opcional - para enviar correos transaccionales)
AZURE_TENANT_ID=tu_tenant_id_aqui
AZURE_CLIENT_ID=tu_client_id_aqui
AZURE_CLIENT_SECRET=tu_client_secret_aqui
MAIL_FROM=soporte@tudominio.com

# Sentry (Opcional - observabilidad)
SENTRY_DSN=https://xxxxxxxx@o0.ingest.sentry.io/0
